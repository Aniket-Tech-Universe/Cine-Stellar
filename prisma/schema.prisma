// Cine-Stellar Prisma Database Schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String?
  name              String?
  role              String         @default("USER") // USER, ADMIN
  avatar            String         @default("avatar_1") // Preset avatar names: avatar_1, avatar_2, etc.
  preferredLanguage String         @default("en")
  theme             String         @default("dark")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  watchHistory      WatchHistory[]
  favorites         Favorite[]
  watchlist         Watchlist[]
  ratings           Rating[]
}

model WatchHistory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId      String
  mediaType    String   // "movie" or "tv"
  title        String
  backdropPath String?
  progress     Float    // playback progress in seconds
  duration     Float    // total duration in seconds
  season       Int?     // For TV shows
  episode      Int?     // For TV shows
  lastWatched  DateTime @default(now()) @updatedAt

  @@unique([userId, mediaId, mediaType])
}

model Favorite {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId      String
  mediaType    String   // "movie" or "tv"
  title        String
  posterPath   String?
  backdropPath String?
  createdAt    DateTime @default(now())

  @@unique([userId, mediaId, mediaType])
}

model Watchlist {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId      String
  mediaType    String   // "movie" or "tv"
  title        String
  posterPath   String?
  backdropPath String?
  createdAt    DateTime @default(now())

  @@unique([userId, mediaId, mediaType])
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId   String
  mediaType String   // "movie" or "tv"
  rating    Int      // 1 to 10 scale or 1 to 5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mediaId, mediaType])
}
